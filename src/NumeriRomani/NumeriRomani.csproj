<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>LinkeEngineering.$(MSBuildProjectName)</AssemblyName>
    <RootNamespace>LinkeEngineering.$(MSBuildProjectName.Replace(" ", "_"))</RootNamespace>
		<Deterministic>true</Deterministic>
    <GeneratePackageOnBuild>False</GeneratePackageOnBuild>
    <Title>$(AssemblyName)</Title>
    <Authors>linke-engineering</Authors>
    <Company>Linke Genealogical Engineering</Company>
    <Description>A modern .NET library for converting, formatting, and parsing Roman numerals. Includes extension methods for int and string, custom formatting support, and validation for Roman numeral strings. Supports numeric values from 0 to 499,999.</Description>
    <PackageReadmeFile>Readme.md</PackageReadmeFile>
    <RepositoryUrl>https://github.com/linke-engineering/numeri-romani.git</RepositoryUrl>
    <PackageTags>roman; numerals; roman numerals; conversion; parse; format; formatter; extension; .NET; C#; validation; numbers; string; int; library</PackageTags>
    <PackageIcon>NumeriRomani.png</PackageIcon>
    <PackageLicenseFile>License.txt</PackageLicenseFile>
    <Copyright>Copyright (c) 2023-2026 Linke Genealogical Engineering</Copyright>
    <Version>1.1.5</Version>
  </PropertyGroup>

  <ItemGroup>
		<None Include="../../Readme.md" Pack="true" PackagePath="Readme.md" />
		<None Include="../../assets/License.txt" Pack="true" PackagePath="License.txt" />
		<None Include="../../assets/NumeriRomani.png" Pack="true" PackagePath="NumeriRomani.png" />
  </ItemGroup>

</Project>
